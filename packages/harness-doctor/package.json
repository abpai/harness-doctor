{
  "name": "@andypai/harness-doctor",
  "version": "0.2.0",
  "description": "Scan a repo's agent-harness readiness: the docs contract (AGENTS.md, docs/ system of record, spec contract), supply-chain hardening, and dead code — with readiness scoring, diff mode, and a GitHub action",
  "keywords": [
    "agents",
    "agents-md",
    "ai-agents",
    "diagnostics",
    "docs-contract",
    "documentation",
    "harness",
    "readiness",
    "scanner",
    "supply-chain",
    "typescript"
  ],
  "homepage": "https://github.com/abpai/harness-doctor#readme",
  "bugs": {
    "url": "https://github.com/abpai/harness-doctor/issues"
  },
  "license": "MIT",
  "author": "Andy Pai",
  "repository": {
    "type": "git",
    "url": "https://github.com/abpai/harness-doctor.git",
    "directory": "packages/harness-doctor"
  },
  "bin": {
    "harness-doctor": "./bin/harness-doctor.js"
  },
  "files": [
    "bin/**",
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/skills/**"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./api": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && cross-env NODE_ENV=production vp pack",
    "typecheck": "tsc --noEmit",
    "test": "vp test run"
  },
  "dependencies": {
    "@babel/code-frame": "^7.29.0",
    "@effect/platform-node-shared": "4.0.0-beta.70",
    "agent-install": "0.0.5",
    "conf": "^15.1.0",
    "confbox": "^0.2.4",
    "deslop-js": "^0.0.15",
    "effect": "4.0.0-beta.70",
    "jiti": "^2.7.0",
    "magicast": "^0.5.3",
    "prompts": "^2.4.2",
    "typescript": ">=5.0.4 <7"
  },
  "devDependencies": {
    "@harness-doctor/api": "workspace:*",
    "@harness-doctor/core": "workspace:*",
    "@types/babel__code-frame": "^7.27.0",
    "@types/prompts": "^2.4.9",
    "@xterm/headless": "^6.0.0",
    "commander": "^14.0.3",
    "ora": "^9.4.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
