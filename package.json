{
  "name": "harness-doctor",
  "private": true,
  "homepage": "https://github.com/abpai/harness-doctor#readme",
  "bugs": {
    "url": "https://github.com/abpai/harness-doctor/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/abpai/harness-doctor.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter=@andypai/harness-doctor",
    "build": "turbo run build",
    "test": "turbo run test --filter=@andypai/harness-doctor --filter=@harness-doctor/core --filter=@harness-doctor/api",
    "typecheck": "turbo run typecheck",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp check",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && bun run check:published-deps && changeset publish",
    "check:published-deps": "node --experimental-strip-types --no-warnings scripts/check-published-deps.ts",
    "smoke:json-report": "node --experimental-strip-types --no-warnings scripts/smoke-json-report.ts",
    "smoke:tty-prompt": "python3 scripts/smoke-tty-prompt.py"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@harness-doctor/core": "workspace:*",
    "@rayhanadev/truffler": "^0.4.2",
    "@types/node": "^25.6.0",
    "@voidzero-dev/vite-plus-core": "^0.1.15",
    "cross-env": "^10.1.0",
    "effect": "4.0.0-beta.70",
    "ts-json-schema-generator": "^2.9.0",
    "turbo": "^2.9.7",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.15"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.15",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.15"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "bun@1.3.3",
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "unrs-resolver"
  ]
}
